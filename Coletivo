    function renderPhases(){
      const btns = document.getElementById('phaseButtons');
      const grid = document.getElementById('phaseGrid');
      btns.innerHTML = '';
      grid.innerHTML = '';
      phases.forEach((p,i)=>{
        const b = document.createElement('button');
        b.textContent = p.title;
        b.className = i===currentPhase ? '' : 'light';
        b.onclick = () => selectPhase(i);
        btns.appendChild(b);

        const card = document.createElement('div');
        card.className = 'metric';
        card.innerHTML = `<span class="badge">Fase ${i+1}</span><h3>${p.title}</h3><p>${p.desc}</p><p class="muted"><strong>${p.time} min</strong></p>`;
        grid.appendChild(card);
      });
      document.getElementById('phaseName').textContent = phases[currentPhase].title;
    }

    function renderRoles(){
      const el = document.getElementById('roles');
      el.innerHTML = '';
      roles.forEach(r=>{
        const c = document.createElement('div');
        c.className = 'role';
        c.innerHTML = `<span class="badge">Papel</span><h3>${r.title}</h3><p>${r.text}</p>`;
        el.appendChild(c);
      });
    }

    function renderSources(){
      const el = document.getElementById('sources');
      el.innerHTML = '';
      sources.forEach(s=>{
        const preview = buildPreview(s.title, s.excerpt, s.kind);
        const c = document.createElement('div');
        c.className = 'source-card';
        c.innerHTML = `
          <button class="source-open no-print" type="button" onclick="openSource('${s.id}')" aria-label="Abrir ${s.title}">
            <div class="source-doc source-doc-compact">
              <div class="source-doc-head">
                <span>Fonte ${s.id}</span>
                <span class="source-stamp">Arquivo de prova</span>
              </div>
