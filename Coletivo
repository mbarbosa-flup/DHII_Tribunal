    function renderArguments(){
      const el = document.getElementById('argumentLog');
      if(!savedArguments.length){ el.innerHTML = '<p class="muted">Sem argumentos registados.</p>'; return; }
      el.innerHTML = savedArguments.map(a=>`<div class="entry"><strong>${a.side}</strong> · <span class="muted">${a.speech}</span><br>${a.text}<br><span class="muted">${a.time}</span></div>`).join('');
    }

    function clearArguments(){ savedArguments.length = 0; renderArguments(); }

    function downloadArguments(){
      const text = savedArguments.map(a=>`${a.side} | ${a.speech} | ${a.text}`).join('\n\n') || 'Sem argumentos.';
      const blob = new Blob([text],{type:'text/plain;charset=utf-8'});
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'argumentos_wiriyamu.txt';
      a.click();
      URL.revokeObjectURL(a.href);
    }

    function compareSources(){
      const a = sources.find(s=>s.id === document.getElementById('compareSource1').value);
      const b = sources.find(s=>s.id === document.getElementById('compareSource2').value);
      const output = document.getElementById('compareOutput');
      if(!a || !b){ output.textContent = 'Escolhe duas fontes válidas.'; return; }
      output.innerHTML = `<strong>${a.title}</strong> e <strong>${b.title}</strong> convergem porque ambas participam na disputa pelo sentido de Wiriyamu. Divergem porque <strong>${a.title}</strong> trabalha sobretudo ${a.takeaway.toLowerCase()} e <strong>${b.title}</strong> trabalha sobretudo ${b.takeaway.toLowerCase()}.<br><br><strong>Tensão principal:</strong> ${a.problem} / ${b.problem}`;
    }

    function generateVerdict(){
      const student = document.getElementById('studentName').value.trim() || 'Aluno/Grupo sem identificação';
      const level = document.getElementById('responsibilityLevel').value;
      const response = document.getElementById('responseType').value;
      const reason = document.getElementById('verdictReason').value.trim() || 'Sem justificação escrita.';
      const evidenceCount = openedSources.size;
      const witnessCount = openedWitnesses.size;
      const verdict = `Aluno/Grupo: ${student}\n\nNível de responsabilidade histórica: ${level}\nTipo de resposta: ${response}\n\nJustificação final:\n${reason}\n\nElementos mobilizados:\n- Provas abertas: ${evidenceCount}/5\n- Testemunhas ouvidas: ${witnessCount}/6\n- Argumentos registados: ${savedArguments.length}\n\nSíntese final:\nO coletivo de juízes entende que Wiriyamu não deve ser visto apenas como um episódio de violência colonial, mas como um caso exemplar da luta pelo poder de dizer a verdade histórica. Entre a propaganda colonial, a denúncia, a negação, a dúvida, o reconhecimento tardio e o debate contemporâneo sobre reparações, o problema central não é apenas o que aconteceu, mas porque razão demorou tanto tempo a poder ser plenamente assumido.\n\nÀ luz dos direitos humanos, da memória histórica e das relações no espaço lusófono, a reparação pode assumir várias formas: reconhecimento público, pedido formal de desculpas, educação histórica, restituição patrimonial, reparação simbólica e debate crítico entre Portugal, Moçambique, Brasil e a CPLP.`;
      document.getElementById('verdictOutput').textContent = verdict;
      addScore(20,'Gerou a deliberação final.');
      updateProgress();
    }

