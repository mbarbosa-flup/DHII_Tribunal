      if(ok && window.html2pdf){
        const wrapper = document.createElement('div');
        wrapper.style.padding = '24px';
        wrapper.style.fontFamily = 'Arial, Helvetica, sans-serif';
        wrapper.innerHTML = `
          <h1 style="color:#4d2d13">Tribunal Histórico de Wiriyamu — Deliberação Final</h1>
          <p><strong>Aluno/Grupo:</strong> ${document.getElementById('studentName').value.trim() || 'Não identificado'}</p>
          <p><strong>Data:</strong> ${new Date().toLocaleDateString('pt-PT')}</p>
          <hr>
          <h2 style="color:#7f4c21">Deliberação</h2>
          <pre style="white-space:pre-wrap;font-family:Arial,Helvetica,sans-serif">${document.getElementById('verdictOutput').textContent}</pre>
          <h2 style="color:#7f4c21">Metarreflexão final</h2>
          <pre style="white-space:pre-wrap;font-family:Arial,Helvetica,sans-serif">${document.getElementById('exitTicket').value || 'Sem resposta.'}</pre>
        `;
        try{
          await window.html2pdf().set({
            margin:[10,10,10,10],
            filename:`${student}.pdf`,
            image:{type:'jpeg',quality:0.98},
            html2canvas:{scale:2,useCORS:true},
            jsPDF:{unit:'mm',format:'a4',orientation:'portrait'}
          }).from(wrapper).save();
          status.textContent = 'PDF descarregado com sucesso.';
          return;
        }catch(err){
          status.textContent = 'A exportação automática falhou. Vai abrir a impressão para Guardar como PDF.';
        }
      } else {
        status.textContent = 'Biblioteca PDF indisponível. Vai abrir a impressão para Guardar como PDF.';
      }
      window.print();
    }

    window.addEventListener('DOMContentLoaded', init);
  </script>
</body>
</html>
