<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tribunal Histórico de Wiriyamu</title>
  <style>
    :root{
      --bg:#f4ede3;
      --paper:#fffaf4;
      --ink:#2f241b;
      --muted:#6b5a49;
      --accent:#7f4c21;
      --accent2:#a66731;
      --line:#e5d4c2;
      --soft:#f8efe3;
      --good:#2d6f47;
      --warn:#aa6d19;
      --danger:#8b3434;
      --shadow:0 12px 28px rgba(0,0,0,.08);
      --radius:20px;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:Arial, Helvetica, sans-serif;
      color:var(--ink);
      background:linear-gradient(180deg,#f7f1e8 0%, #efe1cf 100%);
    }
    header{
      background:linear-gradient(135deg,#4c2b12,#8f592c);
      color:#fff;
      padding:28px 18px;
      box-shadow:var(--shadow);
    }
    header h1{margin:0 0 10px;font-size:clamp(1.8rem,3vw,3rem)}
    header p{margin:0;line-height:1.55;max-width:1080px}
    main{max-width:1280px;margin:22px auto 40px;padding:0 14px;display:grid;gap:16px}
    .card{
      background:var(--paper);
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      padding:18px;
    }
    h2,h3{margin:0 0 10px;color:#4d2d13}
    p{line-height:1.55}
    .badge{
      display:inline-block;
      padding:6px 10px;
      border-radius:999px;
      background:#f0deca;
      color:#603917;
      font-weight:700;
      font-size:.86rem;
      margin-bottom:8px;
    }
    .grid-2{display:grid;grid-template-columns:1.15fr .85fr;gap:16px}
    .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    .grid-auto{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:14px}
    .questionbox{border-left:6px solid var(--accent);background:#fff8f0}
    .metric,.role,.source-card,.witness,.verdictbox,.notesbox,.promptbox{
      border:1px solid var(--line);
      border-radius:16px;
      padding:14px;
      background:#fffdf8;
    }
    .muted{color:var(--muted)}
    .metric strong{display:block;font-size:2rem;color:#4d2d13}
    .progress{height:12px;border-radius:999px;background:#e9dbc9;overflow:hidden;margin-top:8px}
    .progress > span{display:block;height:100%;width:0%;background:linear-gradient(90deg,#c78a3a,#e0b76f);transition:width .3s ease}
    .pillbar,.toolbar{display:flex;gap:10px;flex-wrap:wrap}
    button,a.action{
      border:0;
      border-radius:999px;
      padding:11px 16px;
      font-weight:700;
      cursor:pointer;
      background:var(--accent);
      color:#fff;
      text-decoration:none;
      display:inline-block;
      box-shadow:0 5px 12px rgba(0,0,0,.08);
    }
    button:hover,a.action:hover{background:var(--accent2)}
    button.secondary{background:#5c4a3d}
    button.light{background:#dcc3a8;color:#2f241b}
    button.good{background:var(--good)}
    button.warn{background:var(--warn)}
    button.danger{background:var(--danger)}
    input,select,textarea{
      width:100%;
      padding:12px;
      border-radius:14px;
      border:1px solid #d9c6b1;
      background:#fff;
      font:inherit;
      color:inherit;
    }
    textarea{min-height:140px}
    .preview{
      width:100%;
      aspect-ratio: 900 / 520;
      height:auto;
      object-fit:contain;
      border-radius:4px;
      border:1px solid #ceb89f;
      background:#f4ecdf;
      margin:0;
      box-shadow:none;
      display:block;
    }
    .source-card{
      align-self:start;
      background:transparent;
      border:0;
      border-radius:0;
      padding:0;
      box-shadow:none;
      position:relative;
      overflow:visible;
      display:flex;
      flex-direction:column;
      gap:10px;
    }
    .source-doc{
      background:#f6eedf;
      border:1px solid #d4bea2;
      border-radius:14px;
      padding:12px;
      margin-bottom:0;
      box-shadow:0 6px 16px rgba(0,0,0,.04), inset 0 0 0 1px rgba(255,255,255,.55);
    }
    .source-doc-head{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
      margin-bottom:10px;
      padding:0 2px 8px 2px;
      border-bottom:2px solid #ccb396;
      color:#6a4b2a;
      font-size:.78rem;
      letter-spacing:.08em;
      text-transform:uppercase;
      font-weight:700;
    }
    .source-stamp{
      display:inline-block;
      border:2px solid #a24f39;
      color:#a24f39;
      padding:6px 9px;
      border-radius:4px;
      transform:rotate(-4deg);
      background:rgba(162,79,57,.04);
      font-size:.71rem;
      white-space:nowrap;
      font-weight:800;
      letter-spacing:.06em;
      text-transform:uppercase;
    }
    .source-open{
      display:block;
      width:100%;
      background:none;
      border:0;
      padding:0;
      margin:0;
      box-shadow:none;
      border-radius:0;
      color:inherit;
      text-align:left;
    }
    .source-open:hover{background:none}
    .source-open:focus-visible{
      outline:3px solid rgba(127,76,33,.28);
      outline-offset:4px;
      border-radius:12px;
    }
    .source-doc-compact{
      margin-bottom:0;
      cursor:pointer;
    }
    .source-caption{
      padding:0 4px;
    }
    .source-caption h3{
      margin-bottom:0;
      font-size:1rem;
      color:#5b3a1d;
      text-align:center;
      letter-spacing:.03em;
    }
    .source-caption p{
      margin:0;
    }

    .source-card h3{
      margin-top:0;
      margin-bottom:0;
      line-height:1.12;
    }
    .tag{
      display:inline-block;
      margin:2px 4px 2px 0;
      padding:3px 7px;
      border-radius:4px;
      background:#f2e7da;
      border:1px solid #dcc6ae;
      font-size:.77rem;
      text-transform:uppercase;
      letter-spacing:.03em;
    }

    .source-problem-inline{
      margin-top:8px;
      padding:10px 12px;
      background:#fffdf9;
      border-left:4px solid #a66731;
      border-radius:6px;
    }
    .log{max-height:280px;overflow:auto;border:1px dashed #d3b596;border-radius:14px;background:#fcf7ef;padding:12px}
    .entry{padding:8px 0;border-bottom:1px solid #eee0d1}
    .entry:last-child{border-bottom:0}
    .quote{background:#fffdf9;border:1px solid #e2d2bf;border-left:4px solid var(--accent);padding:14px;border-radius:8px;white-space:pre-wrap}
    .quote a{color:var(--accent);font-weight:700;word-break:break-word}
    .modal{position:fixed;inset:0;background:rgba(32,23,16,.56);display:none;align-items:center;justify-content:center;padding:14px;z-index:1000}
    .modal.open{display:flex}
    .modal-card{width:min(980px,100%);max-height:92vh;overflow:auto;background:var(--paper);border-radius:20px;border:1px solid var(--line);box-shadow:0 18px 40px rgba(0,0,0,.22);padding:18px}
    .closebar{display:flex;justify-content:space-between;align-items:center;gap:10px}
    .split{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .status{font-weight:700;color:#5b3d1f}
    .footer-note{text-align:center;color:var(--muted);padding:0 18px 32px}
    .small{font-size:.92rem}
    @media (max-width:980px){.grid-2,.grid-3,.split{grid-template-columns:1fr}}
    @media print{
      body{background:#fff}
      .no-print{display:none !important}
      .card{box-shadow:none;break-inside:avoid}
      main{max-width:none;margin:0;padding:0}
    }
  </style>
</head>
<body>
  <header>
    <h1>⚖️ Tribunal Histórico de Wiriyamu</h1>
    <p>Recurso interativo para História A — 12.º ano. Aqui, o massacre de Wiriyamu não aparece apenas como acontecimento: surge como <strong>conflito entre denúncia, negação, dúvida, reconhecimento tardio e debate sobre reparações no espaço lusófono</strong>. Os alunos analisam fontes, confrontam vozes históricas e constroem uma deliberação fundamentada.</p>
  </header>

  <main>
    <section class="card questionbox">
      <span class="badge">Questão central</span>
      <h2>Quando uma violência colonial é negada, quem decide a verdade histórica e a responsabilidade no presente?</h2>
      <p>O objetivo não é produzir uma resposta rápida, mas construir um <strong>juízo histórico fundamentado</strong> sobre o que foi dito, ocultado, relativizado e finalmente reconhecido. O caso de Wiriyamu obriga os alunos a pensar não só nos factos, mas também no <strong>poder de definir os factos</strong>, na memória colonial, nos direitos humanos e nas formas contemporâneas de reparação.</p>
    </section>

    <section class="card">
      <span class="badge">Chave de leitura</span>
      <p><strong>Estas provas não mostram apenas o massacre de Wiriyamu; mostram cinco operações sobre o passado:</strong> denunciar, negar, lançar dúvida, reconhecer e reparar.</p>
    </section>

    <section class="card">
      <h2>1. Enquadramento temporal do problema</h2>

      <div style="display:grid;gap:12px;margin-top:14px">

        <div style="border-left:6px solid #1f4f82;padding:12px 14px;background:#fffdf8;border-radius:14px;border:1px solid #e5d4c2">
          <strong>1972-1973 — Massacre, denúncia e controvérsia internacional</strong><br>
          O caso de Wiriyamu torna-se conhecido internacionalmente através de denúncias missionárias e jornalísticas, com destaque para Adrian Hastings e para a imprensa britânica.
        </div>

        <div style="border-left:6px solid #1f4f82;padding:12px 14px;background:#fffdf8;border-radius:14px;border:1px solid #e5d4c2">
          <strong>1974-1975 — Revolução e descolonização</strong><br>
          O fim da ditadura e da Guerra Colonial altera o contexto político português, mas o debate público sobre responsabilidades coloniais permanece limitado.
        </div>

        <div style="border-left:6px solid #1f4f82;padding:12px 14px;background:#fffdf8;border-radius:14px;border:1px solid #e5d4c2">
          <strong>1996 — Criação da CPLP</strong><br>
          A criação da CPLP reforça a cooperação entre países de língua portuguesa e reabre discussões sobre memória colonial e relações pós-coloniais.
        </div>

        <div style="border-left:6px solid #1f4f82;padding:12px 14px;background:#fffdf8;border-radius:14px;border:1px solid #e5d4c2">
          <strong>2022 — Pedido de desculpas de António Costa em Moçambique</strong><br>
          O massacre regressa ao espaço público português como tema de memória, reconhecimento e responsabilidade histórica.
        </div>

        <div style="border-left:6px solid #1f4f82;padding:12px 14px;background:#fffdf8;border-radius:14px;border:1px solid #e5d4c2">
          <strong>2023-2024 — Debate contemporâneo sobre colonialismo e reparações</strong><br>
          Declarações públicas sobre escravatura, património e reparações recolocam o passado colonial no debate político e mediático.
        </div>

      </div>
    </section>

    <section class="card no-print">
      <h2>🎮 Painel do recurso</h2>
      <div class="grid-3">
        <div class="metric"><span class="badge">Pontuação</span><strong id="score">0</strong><span class="muted">ganha pontos ao abrir provas, testemunhas e concluir a deliberação</span></div>
        <div class="metric"><span class="badge">Progresso</span><strong id="progressText">0%</strong><div class="progress"><span id="progressBar"></span></div></div>
        <div class="metric"><span class="badge">Missão atual</span><p id="mission">Abre uma prova e começa a análise histórica.</p></div>
      </div>
    </section>

    <section class="grid-2">
      <section class="card no-print">
        <h2>2. Fases do tribunal</h2>
        <div class="pillbar" id="phaseButtons"></div>
        <div class="grid-auto" id="phaseGrid"></div>
      </section>
      <section class="card no-print">
        <h2>3. Cronómetro</h2>
        <div class="metric">
          <span class="badge">Tempo da fase</span>
          <strong id="clock">15:00</strong>
          <p class="muted">Fase atual: <span id="phaseName">Preparação</span></p>
          <div class="toolbar">
            <button onclick="startTimer()">Iniciar</button>
            <button class="secondary" onclick="pauseTimer()">Pausar</button>
            <button class="light" onclick="resetTimer()">Repor</button>
          </div>
        </div>
      </section>
    </section>

    <section class="card">
      <h2>4. Papéis do tribunal</h2>
      <div class="grid-auto" id="roles"></div>
    </section>

    <section class="card">
      <h2>5. Provas do tribunal</h2>
      <p class="muted">Cada prova surge como um arquivo de prova. Clica no arquivo para abrir o excerto, a referência e o guião de leitura.</p>
      <div class="grid-auto" id="sources"></div>
    </section>

    <section class="card">
      <h2>6. Testemunhas históricas</h2>
      <p class="muted">As testemunhas não substituem as provas: ajudam a problematizar o que está em jogo em cada narrativa.</p>
      <div class="grid-auto" id="witnesses"></div>
    </section>

    <section class="grid-2 no-print">
      <section class="card">
        <h2>7. Construtor de argumentos</h2>
        <div class="split">
          <div>
            <label class="muted">Tipo de discurso</label>
            <select id="speechType">
              <option value="Discurso de época">Discurso de época</option>
              <option value="Leitura atual">Leitura atual</option>
              <option value="Leitura jurídica/ética">Leitura jurídica/ética</option>
            </select>
          </div>
          <div>
            <label class="muted">Posição</label>
            <select id="sideType">
              <option value="Adrian Hastings — missionário denunciante">Adrian Hastings — missionário denunciante</option>
              <option value="Representante do Estado Novo">Representante do Estado Novo</option>
              <option value="Diplomata / observador internacional">Diplomata / observador internacional</option>
              <option value="Sobrevivente / população local">Sobrevivente / população local</option>
              <option value="Coletivo de juízes: ONU, TEDH e CPLP">Coletivo de juízes: ONU, TEDH e CPLP</option>
              <option value="José Chimunga — símbolo da propaganda colonial">José Chimunga — símbolo da propaganda colonial</option>
              <option value="Representante do Brasil no espaço lusófono">Representante do Brasil no espaço lusófono</option>
            </select>
          </div>
        </div>
        <div style="margin-top:12px">
          <label class="muted">Argumento</label>
          <textarea id="argumentText" placeholder="Ex.: A denúncia internacional não prova tudo por si só, mas rompe a invisibilidade política do massacre."></textarea>
        </div>
        <div class="toolbar">
          <button onclick="saveArgument()">Guardar argumento</button>
          <button class="secondary" onclick="clearArguments()">Limpar</button>
          <button class="light" onclick="downloadArguments()">Descarregar</button>
        </div>
      </section>

      <section class="card">
        <h2>8. Registo do julgamento</h2>
        <div id="argumentLog" class="log"></div>
      </section>
    </section>

    <section class="card no-print">
      <h2>9. Comparador de fontes</h2>
      <p class="muted">Escolhe duas provas e identifica convergências, tensões e problemas de interpretação.</p>
      <div class="split">
        <div>
          <label class="muted">Fonte 1</label>
          <select id="compareSource1"></select>
        </div>
        <div>
          <label class="muted">Fonte 2</label>
          <select id="compareSource2"></select>
        </div>
      </div>
      <div class="toolbar">
        <button class="warn" onclick="compareSources()">Comparar fontes</button>
      </div>
      <div id="compareOutput" class="quote" style="margin-top:12px">A comparação aparecerá aqui.</div>
    </section>

    <section class="card" id="studentWork">
      <h2>10. Deliberação final do coletivo de juízes</h2>
      <div class="grid-3">
        <div class="verdictbox">
          <span class="badge">Aluno / grupo</span>
          <input id="studentName" placeholder="Escreve o nome do aluno ou do grupo" />
        </div>
        <div class="verdictbox">
          <span class="badge">Nível de responsabilidade</span>
          <select id="responsibilityLevel">
            <option value="Baixa">Baixa</option>
            <option value="Média">Média</option>
            <option value="Elevada">Elevada</option>
          </select>
        </div>
        <div class="verdictbox">
          <span class="badge">Tipo de resposta</span>
          <select id="responseType">
            <option value="Reconhecimento público">Reconhecimento público</option>
            <option value="Pedido formal de desculpas">Pedido formal de desculpas</option>
            <option value="Educação e memória pública">Educação e memória pública</option>
            <option value="Reparação simbólica">Reparação simbólica</option>
            <option value="Resposta combinada">Resposta combinada</option>
          </select>
        </div>
      </div>
      <div style="margin-top:12px">
        <label class="muted">Justificação final do coletivo de juízes</label>
        <textarea id="verdictReason" placeholder="Escreve a decisão fundamentada do coletivo de juízes..."></textarea>
      </div>
      <div class="toolbar no-print">
        <button class="good" onclick="generateVerdict()">Gerar deliberação</button>
        <button class="light" onclick="copyVerdict()">Copiar deliberação</button>
        <button class="warn" onclick="exportPdf()">Descarregar PDF</button>
      </div>
      <div id="pdfStatus" class="status no-print" style="margin-top:10px"></div>
      <div id="verdictOutput" class="quote" style="margin-top:12px">A deliberação final aparecerá aqui.</div>
    </section>

    <section class="card" id="exitSection">
      <h2>11. Metarreflexão final</h2>
      <div class="grid-2">
        <div class="promptbox">
          <span class="badge">Pergunta de fecho</span>
          <p><strong>O julgamento que fizemos foi justo ou ficou condicionado pelos valores do presente?</strong></p>
          <p class="muted">Esta pergunta ajuda a evitar o presentismo: os alunos devem distinguir condenação moral imediata, contextualização histórica e responsabilidade pública.</p>
        </div>
        <div class="notesbox">
          <label class="muted">Resposta individual / Exit ticket</label>
          <textarea id="exitTicket" placeholder="O passado colonial deve influenciar decisões atuais? Justifica com base em evidência histórica."></textarea>
          <div class="toolbar no-print"><button class="light" onclick="copyExitTicket()">Copiar resposta</button></div>
        </div>
      </div>
    </section>
  </main>

  <div class="modal" id="sourceModal">
    <div class="modal-card">
      <div class="closebar">
        <div>
          <span class="badge" id="modalType">Fonte</span>
          <h2 id="modalTitle">Título</h2>
        </div>
        <button class="danger no-print" onclick="closeSourceModal()">Fechar</button>
      </div>
      <img id="modalImage" class="preview" alt="Imagem da prova" />
      <p class="muted" id="modalMeta"></p>
      <div class="quote" id="modalText"></div>
      <p style="margin-top:12px"><strong>Referência bibliográfica:</strong> <span id="modalRef"></span></p>
      <p><strong>Ligação externa:</strong> <a id="modalLink" href="#" target="_blank" rel="noopener noreferrer">Abrir fonte</a></p>
      <h3 style="margin-top:14px">Guião de leitura</h3>
      <div id="modalQuestions"></div>
      <h3 style="margin-top:14px">Notas do grupo</h3>
      <textarea id="modalNotes" placeholder="Regista aqui a leitura da fonte, dúvidas, relações e argumentos..."></textarea>
      <div class="toolbar no-print"><button onclick="saveSourceNotes()">Guardar análise</button></div>
    </div>
  </div>

  <div class="modal" id="witnessModal">
    <div class="modal-card">
      <div class="closebar">
        <div>
          <span class="badge">Testemunha</span>
          <h2 id="witnessTitle">Título</h2>
        </div>
        <button class="danger no-print" onclick="closeWitnessModal()">Fechar</button>
      </div>
      <p class="muted" id="witnessMeta"></p>
      <div class="quote" id="witnessText"></div>
      <h3 style="margin-top:14px">Pistas para a argumentação</h3>
      <div id="witnessPrompts"></div>
    </div>
  </div>

  <p class="footer-note">Ficheiro HTML autónomo. Funciona no navegador e exporta a deliberação final em PDF, com alternativa de impressão caso a biblioteca externa não carregue.</p>

  <script>
    const phases = [
      { title:'Preparação', time:15, desc:'Distribuir papéis, abrir as primeiras provas e definir o problema histórico.' },
      { title:'Abertura', time:5, desc:'O coletivo de juízes apresenta a questão central e relembra que o tribunal julga versões do passado.' },
      { title:'Análise de provas', time:20, desc:'Os grupos analisam as cinco provas e registam leitura crítica.' },
      { title:'Testemunhas', time:15, desc:'Adrian Hastings, Estado, diplomata, sobrevivente e Brasil ajudam a complexificar a interpretação.' },
      { title:'Confronto de narrativas', time:10, desc:'Cada papel constrói argumentos a partir das fontes e das suas tensões.' },
      { title:'Deliberação', time:15, desc:'O coletivo de juízes formula a deliberação final sobre responsabilidade histórica.' }
    ];

    const roles = [
      {title:'Coletivo de juízes', text:'Modera o processo e garante que o debate se apoia em provas, não em opiniões soltas. Integra olhares da ONU, do Tribunal Europeu dos Direitos Humanos e da CPLP.'},
      {title:'Adrian Hastings — missionário denunciante', text:'Representa quem tornou o massacre visível no espaço internacional e rompeu o silêncio oficial.'},
      {title:'Representante do Estado Novo', text:'Representa a voz que negou o massacre e tentou manter o controlo da narrativa.'},
      {title:'Diplomata / observador internacional', text:'Representa a estratégia da dúvida: não absolve inteiramente, mas relativiza e atrasa a condenação.'},
      {title:'Sobrevivente / população local', text:'Representa os silenciados e devolve à discussão a dimensão humana e concreta da violência.'},
      {title:'José Chimunga — símbolo da propaganda colonial', text:'Ajuda a problematizar a forma como a propaganda colonial construiu imagens de integração, harmonia e legitimidade do império português.'},
      {title:'Representante do Brasil no espaço lusófono', text:'Relaciona o debate sobre reparações com escravatura, património, racismo estrutural e memória colonial.'},
      {title:'Coletivo do presente', text:'Representa a sociedade atual e decide que responsabilidade histórica resulta da denúncia, da negação, da dúvida, do reconhecimento tardio e do debate sobre reparações.'}
    ];

    const sources = [
      {
        id:'A',
        kind:'Recorte de imprensa / denúncia internacional',
