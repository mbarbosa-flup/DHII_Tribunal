            </div>
          </button>
          <div class="source-caption">
            <h3>Fonte ${s.id}</h3>
          </div>
          <div class="toolbar no-print">
            <button onclick="openSource('${s.id}')">Abrir arquivo</button>
            <a class="action" href="${s.link}" target="_blank" rel="noopener noreferrer">${s.button}</a>
          </div>
        `;
        el.appendChild(c);
      });
