    function saveArgument(){
      const speech = document.getElementById('speechType').value;
      const side = document.getElementById('sideType').value;
      const text = document.getElementById('argumentText').value.trim();
      if(!text) return;
      savedArguments.unshift({speech, side, text, time:new Date().toLocaleTimeString('pt-PT',{hour:'2-digit',minute:'2-digit'})});
      document.getElementById('argumentText').value = '';
      renderArguments();
      addScore(14,'Guardou um argumento.');
