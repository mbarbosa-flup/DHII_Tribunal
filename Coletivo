    function renderCompareSelects(){
      const s1 = document.getElementById('compareSource1');
      const s2 = document.getElementById('compareSource2');
      const options = sources.map(s=>`<option value="${s.id}">${s.title}</option>`).join('');
      s1.innerHTML = options;
      s2.innerHTML = options;
      if(sources[1]) s2.value = sources[1].id;
    }

    function selectPhase(i){
      currentPhase = i;
      remaining = phases[i].time * 60;
      pauseTimer();
      renderPhases();
      updateClock();
      addScore(5,'Mudou de fase.');
    }

    function updateClock(){
      const m = String(Math.floor(remaining/60)).padStart(2,'0');
      const s = String(remaining%60).padStart(2,'0');
      document.getElementById('clock').textContent = `${m}:${s}`;
    }
    function startTimer(){
      if(timer) return;
      timer = setInterval(()=>{
        if(remaining>0){ remaining--; updateClock(); }
        else { pauseTimer(); alert('Tempo terminado para esta fase.'); }
      },1000);
    }
    function pauseTimer(){ clearInterval(timer); timer = null; }
    function resetTimer(){ remaining = phases[currentPhase].time * 60; pauseTimer(); updateClock(); }

    function openSource(id){
      const s = sources.find(x=>x.id===id);
      currentSourceId = id;
      const preview = buildPreview(s.title, s.excerpt, s.kind);
      document.getElementById('modalType').textContent = s.kind;
      document.getElementById('modalTitle').textContent = s.title;
      document.getElementById('modalMeta').textContent = s.meta;
      document.getElementById('modalImage').src = preview;
      document.getElementById('modalText').innerHTML = `<p><strong>Excerto:</strong> ${s.excerpt}</p><p><strong>Leitura crítica:</strong> ${s.analysis}</p><div class="source-problem-inline"><strong>Problema histórico:</strong> ${s.problem}</div>`;
      document.getElementById('modalRef').textContent = s.reference;
      const link = document.getElementById('modalLink');
      link.href = s.link;
      link.textContent = s.button;
      document.getElementById('modalQuestions').innerHTML = '<ul>'+s.questions.map(q=>`<li>${q}</li>`).join('')+'</ul>';
      document.getElementById('modalNotes').value = localStorage.getItem('sourceNotes_'+id) || '';
      document.getElementById('sourceModal').classList.add('open');
      if(!openedSources.has(id)){
        openedSources.add(id);
        addScore(12,'Abriu uma prova.');
      }
      updateProgress();
    }

    function closeSourceModal(){ document.getElementById('sourceModal').classList.remove('open'); }

    function saveSourceNotes(){
      if(currentSourceId){
