    function buildPreview(title, excerpt, kind){
      const safe = (s) => String(s)
        .replace(/&/g,'&amp;')
        .replace(/</g,'&lt;')
        .replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;')
        .replace(/'/g,'&#39;');
      const svg = `
        <svg xmlns="http://www.w3.org/2000/svg" width="900" height="520" viewBox="0 0 900 520">
          <defs>
            <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#f7efe4"/>
              <stop offset="100%" stop-color="#ead8c3"/>
            </linearGradient>
          </defs>
          <rect width="900" height="520" fill="url(#g)"/>
          <rect x="28" y="28" width="844" height="464" rx="28" fill="#fffaf4" stroke="#dcc8b1" stroke-width="3"/>
          <foreignObject x="58" y="56" width="784" height="58">
            <div xmlns="http://www.w3.org/1999/xhtml" style="font-family:Arial,Helvetica,sans-serif;font-size:26px;font-weight:700;line-height:1.15;color:#7f4c21;white-space:normal;overflow-wrap:anywhere;">${safe(kind)}</div>
          </foreignObject>
          <foreignObject x="58" y="116" width="784" height="96">
            <div xmlns="http://www.w3.org/1999/xhtml" style="font-family:Arial,Helvetica,sans-serif;font-size:38px;font-weight:700;line-height:1.08;color:#4d2d13;white-space:normal;overflow-wrap:anywhere;">${safe(title)}</div>
          </foreignObject>
          <rect x="58" y="224" width="784" height="4" fill="#d8c1a6"/>
          <foreignObject x="58" y="248" width="784" height="168">
            <div xmlns="http://www.w3.org/1999/xhtml" style="font-family:Arial,Helvetica,sans-serif;font-size:28px;line-height:1.35;color:#2f241b;display:flex;align-items:flex-start;height:100%;white-space:normal;overflow-wrap:anywhere;">
              <div><strong>Excerto:</strong> ${safe(excerpt)}</div>
            </div>
          </foreignObject>
          <text x="58" y="470" font-family="Arial, Helvetica, sans-serif" font-size="24" fill="#6b5a49">Cartão adaptado para leitura didática</text>
        </svg>`;
      return 'data:image/svg+xml;charset=UTF-8,' + encodeURIComponent(svg);
    }

    function init(){
